{
  "name": "opencode-top",
  "version": "3.3.7",
  "description": "Monitor OpenCode AI coding sessions - Token usage, costs, and agent analytics",
  "type": "module",
  "bin": {
    "opencode-top": "bin/octop.js"
  },
  "scripts": {
    "build": "node build.mjs",
    "prepublishOnly": "node build.mjs",
    "dev": "tsc --watch",
    "start": "node --import tsx src/cli.ts",
    "lint": "biome check src",
    "format": "biome format src --write",
    "test": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "better-sqlite3": "^11.7.0",
    "commander": "^12.1.0",
    "decimal.js": "^10.4.3",
    "ink": "^5.0.1",
    "ink-text-input": "^6.0.0",
    "react": "^18.3.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/better-sqlite3": "^7.6.11",
    "@types/node": "^22.10.5",
    "@types/react": "^18.3.3",
    "esbuild": "^0.27.4",
    "patch-package": "^8.0.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "engines": {
    "node": ">=20"
  },
  "keywords": [
    "opencode",
    "ai",
    "monitoring",
    "tui",
    "cli"
  ],
  "license": "MIT"
}
